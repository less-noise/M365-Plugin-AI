<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:type="TaskPaneApp">

  <Id>c3d4e5f6-a7b8-9012-cdef-123456789012</Id>
  <Version>1.0.0</Version>
  <ProviderName>AI Office Assistant</ProviderName>
  <DefaultLocale>zh-CN</DefaultLocale>
  <DisplayName DefaultValue="PPT AI Assistant" />
  <Description DefaultValue="DeepSeek AI powered presentation assistant" />

  <Hosts>
    <Host Name="Presentation" />
  </Hosts>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://127.0.0.1:3000/ppt/taskpane.html" />
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

  <Requirements>
    <Sets DefaultMinVersion="1.1">
      <Set Name="PowerPointApi" MinVersion="1.1" />
    </Sets>
  </Requirements>

</OfficeApp>
